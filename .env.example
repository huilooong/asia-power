# AsiaPower production environment (copy to .env on server — never commit .env)

# Required on first boot
ADMIN_PASSWORD=

# Google OAuth emails that receive role=admin (comma-separated). Do NOT add unrelated emails.
# Production CEO account is gooddlong@gmail.com (typo variant googddlong also listed if needed).
ADMIN_EMAIL_ALLOWLIST=gooddlong@gmail.com

# QXB VIN decode API (VinDecoder/decode v4.6.0 — http://open.qxbapp.com/interface)
# Auth scheme not yet confirmed — see server/lib/vin/qxb-client.js
QXB_APPID=
QXB_SECRET=

# Production hardening
NODE_ENV=production
COOKIE_SECURE=1
SUPPLIER_GATE=1
REGISTRATION_ENABLED=0

# Supplier upload page API key (required in production; written to supplier-portal/upload-key.js on deploy)
SUPPLIER_UPLOAD_KEY=

# Signed URLs for pending media (required in production; separate from upload key)
MEDIA_ACCESS_SECRET=

# Server
PORT=8080
BIND_HOST=127.0.0.1
INVENTORY_SITE_ROOT=

# Optional notifications
ASIAPOWER_TELEGRAM_BOT_TOKEN=
ASIAPOWER_TELEGRAM_CHAT_ID=

# Cloudflare (API Token — not Global API Key)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_R2_BUCKET=asia-power-media
CLOUDFLARE_R2_PUBLIC_BASE=https://media.asia-power.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Google Analytics 4 Data API (for scripts/fetch-ga4-report.mjs)
# Measurement ID on site: G-PB2J3VRX5J — property ID is numeric (Admin → Property settings)
GA4_PROPERTY_ID=
GA4_MEASUREMENT_ID=G-PB2J3VRX5J
GOOGLE_APPLICATION_CREDENTIALS=

# Google Places API — Maps 客户开发备用（FB 受限时）
# Cloud Console → APIs → Places API → 创建 Key，限制 IP/域名
GOOGLE_PLACES_API_KEY=

# Google Cloud Vision OCR（WhatsApp 铭牌识图；每月约 1000 张免费）
# 同一 GCP 项目启用 Vision API 后，可与 Places 共用 Key，或单独建 Key：
# https://console.developers.google.com/apis/api/vision.googleapis.com/overview
GOOGLE_CLOUD_VISION_API_KEY=
APSALES_GOOGLE_VISION_API_KEY=
# tesseract | google | openai
APSALES_OCR_PROVIDER=tesseract

# Google Speech-to-Text（WhatsApp 语音；约每月 60 分钟免费）
# 同一 GCP Key 启用 Speech API 并放行即可；也可单独设：
GOOGLE_SPEECH_API_KEY=
APSALES_GOOGLE_SPEECH_API_KEY=
# none | google | openai | assemblyai
APSALES_STT_PROVIDER=none
APSALES_VOICE_STT_ENABLED=true
APSALES_STT_LANGUAGE=en-US

# AsiaPower AI OS (python main.py)
OPENAI_API_KEY=

# COO Telegram bot — independent from ASIAPOWER_TELEGRAM_* (integrations/telegram_coo_bot.py)
COO_TELEGRAM_BOT_TOKEN=
COO_TELEGRAM_ALLOWED_CHAT_IDS=

# APSales internal work console (separate bot — NOT customer-facing)
APSALES_TELEGRAM_BOT_TOKEN=
APSALES_TELEGRAM_ALLOWED_CHAT_IDS=

# WhatsApp Business App live read-only connector (APLIVE-002 / APLIVE-002A — NOT Cloud API)
WHATSAPP_CONNECTOR_MODE=business_web_readonly
WHATSAPP_LIVE_ADAPTER=browser
WHATSAPP_AUTO_SEND_LOW_RISK=0
# Required in addition to WHATSAPP_AUTO_SEND_LOW_RISK=1 before any real customer send is possible.
# WHATSAPP_AUTO_SEND_ACK_RISK=I_UNDERSTAND_CUSTOMER_SEND_RISK
# Low-risk auto-send guardrails (子敬自动接单 — 防无限刷屏熔断)
# WHATSAPP_AUTO_SEND_MAX_PER_RUN=3
# WHATSAPP_AUTO_SEND_MAX_GLOBAL_HOUR=20
# WHATSAPP_AUTO_SEND_MAX_PER_CONTACT_HOUR=4
# WHATSAPP_AUTO_SEND_MIN_CONTACT_INTERVAL_SEC=120
# Circuit breaker: pause when same customer gets two consecutive identical auto-replies
APSALES_NOTIFY_ALL_DRAFTS=0
WHATSAPP_LIVE_INBOX=memory/customer_gateway/live_inbox
WHATSAPP_SESSION_DIR=memory/customer_gateway/whatsapp_session
WHATSAPP_SEND_ENABLED=false
WHATSAPP_MARK_READ_ENABLED=false
WHATSAPP_BROWSER_HEADLESS=false
# Sidebar preview can misread our own "You:" messages as inbound. Keep off unless debugging.
# WHATSAPP_ALLOW_SIDEBAR_FALLBACK=0
# WHATSAPP_POLL_RECENT_MESSAGES=20
# WHATSAPP_POLL_MAX_CHATS=15
# WHATSAPP_CONNECT_TIMEOUT_SEC=120
# Optional: custom mock inbound JSON when WHATSAPP_LIVE_ADAPTER=mock
# WHATSAPP_MOCK_SAMPLE_FILE=tests/fixtures/sample_live_inbound.json

# WhatsApp Cloud API webhook (Meta Developer Dashboard → Webhooks)
# WhatsApp Cloud API (+86 official). Prefer WHATSAPP_* names; WHATSAPP_CLOUD_* still accepted.
# Never commit real tokens. Rotate if a token was ever pasted into chat/screenshots.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0
# observe | shadow | approval_only | safe | off
WHATSAPP_AUTONOMY_MODE=sandbox
CEO_WHATSAPP_NUMBER=
# sandbox = only CEO_WHATSAPP_NUMBER auto-replies
# live = all real inbound auto-reply; observe = store only
# CEO Telegram monitor (option B): inbound + outbound summaries via ASIAPOWER_TELEGRAM_*
# WHATSAPP_TELEGRAM_MONITOR=off
# live = all real +86 Cloud inbound auto-replies (APWA-NIGHTSHIFT-001); CEO still tagged ceo_test
# observe = store only; off = emergency kill switch
# WHATSAPP_INTERNAL_WA_IDS= optional internal numbers to tag (do not block)
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_WABA_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=

# 子敬 · Email proxy (Cloudflare Email Worker → /api/email/inbound)
EMAIL_INBOUND_SECRET=
EMAIL_PROXY_DOMAIN=asia-power.com
EMAIL_REPLY_LOCAL=reply

# 子敬 · Email outbound Phase 2 (Resend — https://resend.com)
# 发信 Key（Sending access 即可）:
RESEND_API_KEY=
# 域名验证需 Full access Key，运行: node scripts/verify-sales-domain.mjs re_xxx
# RESEND_FULL_KEY=
EMAIL_SEND_ENABLED=0
# 子敬收到 sales@/inquiry@ 来信后自动起草 + 发 CEO 审批邮件（默认开）
EMAIL_AUTO_PROCESS=1
# 子敬自动找客户 + 流量动作（cron，不自动外发；CEO 批准后才发送）
APSALES_GROWTH_AUTOPILOT=0
APSALES_GROWTH_MAX_EMAIL_DRAFTS=5
APSALES_GROWTH_MAX_OUTREACH_DRAFTS=3
# APSALES_GROWTH_ALWAYS_NOTIFY=1
INVENTORY_SITE_ROOT=/root/.openclaw/workspace/inventory-site
EMAIL_FROM_SALES=AsiaPower Sales <sales@asia-power.com>
# 域名未验证前临时用 onboarding@（验证后设 EMAIL_RESEND_USE_FALLBACK=0）
# EMAIL_RESEND_USE_FALLBACK=1
# EMAIL_RESEND_FALLBACK_FROM=AsiaPower Sales <onboarding@resend.dev>

# WeCom (企业微信) — AsiaPower 库存 Agent / internal nickname 子敬 (APSales)
# Admin console app name MUST be: AsiaPower 库存 Agent (not 子敬)
# CEO: see data/knowledge-base/wecom-zijing-setup-runbook.md for admin console steps
# Optional: WECOM_AGENT_DISPLAY_NAME=AsiaPower 库存 Agent  (WeCom @ mention label; defaults to app name)
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=
# Public HTTPS base (admin callback URL = this + WECOM_CALLBACK_PATH). Production: https://asia-power.cn
WECOM_PUBLIC_BASE_URL=
WECOM_CALLBACK_HOST=127.0.0.1
WECOM_CALLBACK_PORT=8791
WECOM_CALLBACK_PATH=/wecom/callback
# Comma-separated whitelists (empty = allow all)
WECOM_ALLOWED_CHAT_IDS=
WECOM_ALLOWED_USER_IDS=
WECOM_REQUIRE_AT_MENTION=1
DOMESTIC_LIGHTHOUSE_IP=124.222.191.164

# 子敬 · Social autopilot (FB / IG / X) — see data/knowledge-base/apsales-social-automation-runbook.md
APSALES_SOCIAL_AUTOPILOT=1
APSALES_SOCIAL_MAX_POSTS_PER_RUN=3
APSALES_SOCIAL_BROWSER_HEADLESS=1
APSALES_SOCIAL_BROWSER_SCAN=1
# APSALES_SOCIAL_SESSIONS_DIR=memory/customer_gateway/social_sessions
# Human-paced FB+X engagement (Africa dealers)
APSALES_SOCIAL_ENGAGEMENT=1
APSALES_SOCIAL_ENGAGEMENT_MAX_PER_RUN=1
APSALES_SOCIAL_SKIP_INSTAGRAM=1
# CEO 子敬 LIVE 看板只读令牌（URL ?token=… 免 Admin 登录）
APSALES_ZIJING_LIVE_TOKEN=
# Meta Graph API (recommended for production)
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
META_GRAPH_API_BASE=https://graph.facebook.com/v21.0
# X API v2 (paid tier may be required)
X_API_BEARER_TOKEN=
X_API_BASE=https://api.twitter.com/2
# Hourly reply scan (scripts/apsales-social-reply-watch.py)
# APSALES_SOCIAL_REPLY_WATCH=1
# APSALES_SOCIAL_SCAN_HOURS=1
# APSALES_SOCIAL_MAX_DRAFTS=5

# ── Buyer portal + Stripe deposit (portal-deposit-v1) ──
# Leave STRIPE_SECRET_KEY empty for demo checkout (local / preview).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_DEMO=1
PUBLIC_BASE_URL=https://asia-power.com

# Phone OTP (supplier + buyer). Without SMS_PROVIDER, demo codes are returned in API JSON.
PHONE_OTP_DEMO=1
PHONE_OTP_DEMO_SUPPLIER=888888
PHONE_OTP_DEMO_BUYER=123456
# SMS_PROVIDER=demo
# SMS_PROVIDER=log

# Buyer OAuth. Google is the public social login; Facebook entry is retired (CEO 2026-07-10).
# Leave Google empty to use demo OAuth redirects.
# Callbacks (must match exactly):
#   https://asia-power.com/api/auth/oauth/google/callback
# Apply helper: node scripts/apply-oauth-credentials.mjs
# OAUTH_DEMO=1
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Facebook keys may remain on server but login start/UI is off unless:
# FACEBOOK_LOGIN_ENABLED=1
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Consumer Facebook Login scopes (only if re-enabled). Default public_profile.
# FACEBOOK_OAUTH_SCOPE=public_profile

