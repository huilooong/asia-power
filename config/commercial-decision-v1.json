{
  "version": "v1",
  "confidence": {
    "advance_min": 0.90,
    "caution_min": 0.60,
    "customer_reported_working_min": 0.72
  },
  "customer_reported_policy": {
    "principle": "Use customer information as a working assumption. Verify only when the commercial risk justifies it.",
    "customer_reported_is_not_verified": true,
    "customer_reported_is_usable": true,
    "verify_when": [
      "high_mismatch_cost",
      "about_to_quote_purchase_or_ship",
      "conflicting_information",
      "customer_uncertainty_or_secondary_source",
      "high_confusion_or_version_risk"
    ],
    "high_confusion_engine_codes": ["2SZ", "3SZ", "G4KD", "G4KE", "G4KC"],
    "repairer_default_verify": true
  },
  "whatsapp_channel": {
    "max_words": 60,
    "max_paragraphs": 3,
    "max_questions": 2,
    "default_questions": 1,
    "include_website_by_default": false,
    "forbid_phrases": [
      "Dear Customer",
      "Dear Sir",
      "Best regards",
      "Looking forward to your reply",
      "AsiaPower Sales Team"
    ]
  },
  "wholesaler_quantity_min": 5,
  "known_wholesaler_hashes": [],
  "engine_code_pattern": "\\b(G4K[A-Z0-9]+|G4NA|G4FC|G4FG|HR1[56]DE|MR20DE|QR25DE?|VQ35DE?|[123][A-Z]{2}(?:-[A-Z0-9]+)?|1NZ|2NZ|2AZ|1AZ|1KD(?:-FTV)?|2KD(?:-FTV)?|2TR(?:-FE)?|K24A\\d?|R20A\\d?)\\b"
}
