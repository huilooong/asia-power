# DEPRECATED 2026-07-24 — replaced by systemd continuous trickle:
#   systemctl status apbd-ca-leads-trickle.service
# Load-gated loop: works when load is low, pauses when busy.
# This cron file is intentionally empty (no schedules) so deploy removes bursty 4h jobs.

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
